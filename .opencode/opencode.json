{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "system-architect",
  "instructions": [
    "Use 'gh' CLI as the default tool for all GitHub write operations (issues, PRs, releases, comments, labels, milestones, branch management). API-based tools are fallback only when gh does not support the operation.",
    "NEVER create, fork, or recreate GitHub repositories. Operate exclusively within the current repository context.",
    "NEVER work against separate repositories, temporary repositories, or test repositories.",
    "Repository-destructive actions (deleting repos, force-pushing to protected branches) require explicit user confirmation."
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "gh *": "allow",
      "gh repo create *": "deny",
      "gh repo fork *": "deny",
      "gh repo delete *": "deny",
      "python *": "allow",
      "pip *": "allow",
      "uv *": "allow",
      "bun *": "allow",
      "npm *": "allow",
      "bash *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "mkdir *": "allow",
      "echo *": "allow",
      "which *": "allow",
      "aiwf *": "allow"
    }
  },
  "agent": {
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    },
    "system-architect": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": {
          "*": "deny",
          "devops-scripter": "allow",
          "doc-retriever": "allow",
          "git-specialist": "allow",
          "tooling-specialist": "allow",
          "native-systems-engineer": "allow",
          "interactive-app-architect": "allow",
          "llm-context-engineer": "allow",
          "obsidian-knowledge-architect": "allow"
        }
      }
    }
  }
}
